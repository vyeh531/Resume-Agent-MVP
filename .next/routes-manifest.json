      "regex": "^/api/resume/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/resume/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/resume/[id]/mark-paid",
      "regex": "^/api/resume/([^/]+?)/mark\\-paid(?:/)?$",
